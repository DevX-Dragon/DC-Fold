{
  "variables": {
    "community_name": "Open Source Forge",
    "main_theme_color": "#27AE60"
  },
  "roles": [
    {
      "name": "Maintainer",
      "color": "#C0392B",
      "hoist": true,
      "permissions": [
        "administrator"
      ]
    },
    {
      "name": "Core Contributor",
      "color": "#8E44AD",
      "hoist": true,
      "permissions": [
        "manage_roles",
        "manage_channels",
        "manage_messages",
        "view_audit_log",
        "move_members"
      ]
    },
    {
      "name": "Contributor",
      "color": "#27AE60",
      "hoist": false,
      "permissions": [
        "change_nickname",
        "send_messages",
        "embed_links",
        "attach_files",
        "read_message_history",
        "add_reactions",
        "connect",
        "speak",
        "use_voice_activation"
      ]
    }
  ],
  "categories": [
    {
      "name": "MAINTAINER DECK",
      "channels": [
        {
          "name": "release-ops",
          "type": "text",
          "requires_staff": true,
          "slowmode": 0,
          "topic": "Private release planning and moderation space for {{community_name}} maintainers.",
          "messages": [
            {
              "title": "Maintainer Access",
              "description": "Coordinate releases, moderation, and contributor escalations here.",
              "color": "#C0392B"
            }
          ]
        }
      ]
    },
    {
      "name": "PROJECT DESK",
      "channels": [
        {
          "name": "announcements",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Release notes, roadmap changes, and official project updates.",
          "messages": [
            {
              "title": "Welcome to {{community_name}}",
              "description": "Explore the roadmap, ask smart questions, and start contributing.",
              "color": "{{main_theme_color}}"
            }
          ]
        },
        {
          "name": "getting-started",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Starter guidance for new contributors and first issues."
        }
      ]
    },
    {
      "name": "BUILD AREA",
      "channels": [
        {
          "name": "general-dev",
          "type": "text",
          "requires_staff": false,
          "slowmode": 3,
          "topic": "Architecture, implementation details, and collaboration discussion."
        },
        {
          "name": "issues-and-bugs",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Bug triage, reproduction notes, and fix tracking."
        },
        {
          "name": "dev-sync",
          "type": "voice",
          "requires_staff": false
        }
      ]
    }
  ]
}
