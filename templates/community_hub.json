{
  "variables": {
    "community_name": "Community Hub",
    "main_theme_color": "#2ECC71"
  },
  "roles": [
    {
      "name": "Owner",
      "color": "#E74C3C",
      "hoist": true,
      "permissions": [
        "administrator"
      ]
    },
    {
      "name": "Moderator",
      "color": "#3498DB",
      "hoist": true,
      "permissions": [
        "manage_roles",
        "manage_channels",
        "view_audit_log",
        "kick_members",
        "ban_members",
        "manage_messages"
      ]
    },
    {
      "name": "Member",
      "color": "#2ECC71",
      "hoist": false,
      "permissions": [
        "change_nickname",
        "send_messages",
        "embed_links",
        "attach_files",
        "read_message_history",
        "mention_everyone",
        "add_reactions",
        "connect",
        "speak",
        "use_voice_activation"
      ]
    }
  ],
  "categories": [
    {
      "name": "STAFF CORNER",
      "channels": [
        {
          "name": "mod-ops",
          "type": "text",
          "requires_staff": true,
          "slowmode": 0,
          "topic": "Internal moderation coordination for {{community_name}}.",
          "messages": [
            {
              "title": "Private Moderator Channel",
              "description": "Handle reports, coordinate responses, and review server operations here.",
              "color": "#E74C3C"
            }
          ]
        }
      ]
    },
    {
      "name": "START HERE",
      "channels": [
        {
          "name": "welcome",
          "type": "text",
          "requires_staff": false,
          "slowmode": 0,
          "topic": "Settle in and meet the people of {{community_name}}."
        },
        {
          "name": "announcements",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Official updates and community-wide notices.",
          "messages": [
            {
              "title": "Welcome to {{community_name}}",
              "description": "Read the updates, say hello, and jump into the main conversation spaces.",
              "color": "{{main_theme_color}}"
            }
          ]
        }
      ]
    },
    {
      "name": "COMMUNITY FLOOR",
      "channels": [
        {
          "name": "general",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Main conversation channel for all members."
        },
        {
          "name": "introductions",
          "type": "text",
          "requires_staff": false,
          "slowmode": 10,
          "topic": "Introduce yourself, your interests, and what brought you here."
        },
        {
          "name": "lounge",
          "type": "voice",
          "requires_staff": false
        }
      ]
    }
  ]
}
