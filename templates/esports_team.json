{
  "variables": {
    "community_name": "Victory Grid",
    "main_theme_color": "#F39C12"
  },
  "roles": [
    {
      "name": "Team Manager",
      "color": "#C0392B",
      "hoist": true,
      "permissions": [
        "administrator"
      ]
    },
    {
      "name": "Coach",
      "color": "#8E44AD",
      "hoist": true,
      "permissions": [
        "manage_roles",
        "manage_channels",
        "manage_messages",
        "move_members",
        "mute_members",
        "deafen_members"
      ]
    },
    {
      "name": "Player",
      "color": "#F39C12",
      "hoist": false,
      "permissions": [
        "change_nickname",
        "send_messages",
        "embed_links",
        "attach_files",
        "read_message_history",
        "add_reactions",
        "connect",
        "speak",
        "use_voice_activation"
      ]
    }
  ],
  "categories": [
    {
      "name": "COACH BOX",
      "channels": [
        {
          "name": "strategy-board",
          "type": "text",
          "requires_staff": true,
          "slowmode": 0,
          "topic": "Private tactical planning for {{community_name}} leadership.",
          "messages": [
            {
              "title": "Team Staff Only",
              "description": "Review match plans, roster decisions, and scrim notes in this room.",
              "color": "#C0392B"
            }
          ]
        },
        {
          "name": "coach-comms",
          "type": "voice",
          "requires_staff": true
        }
      ]
    },
    {
      "name": "TEAM HQ",
      "channels": [
        {
          "name": "announcements",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Match notices, roster updates, and official team announcements.",
          "messages": [
            {
              "title": "Welcome to {{community_name}}",
              "description": "Check the schedule, stay ready for scrims, and support the roster.",
              "color": "{{main_theme_color}}"
            }
          ]
        },
        {
          "name": "team-chat",
          "type": "text",
          "requires_staff": false,
          "slowmode": 3,
          "topic": "Daily team coordination and general esports chatter."
        }
      ]
    },
    {
      "name": "COMPETITION ZONE",
      "channels": [
        {
          "name": "scrim-room",
          "type": "text",
          "requires_staff": false,
          "slowmode": 3,
          "topic": "Practice planning, VOD notes, and post-match takeaways."
        },
        {
          "name": "match-day",
          "type": "voice",
          "requires_staff": false
        }
      ]
    }
  ]
}
