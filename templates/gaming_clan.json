{
  "variables": {
    "community_name": "Nightfall Clan",
    "main_theme_color": "#8E44AD"
  },
  "roles": [
    {
      "name": "Clan Leader",
      "color": "#C0392B",
      "hoist": true,
      "permissions": [
        "administrator"
      ]
    },
    {
      "name": "Officer",
      "color": "#8E44AD",
      "hoist": true,
      "permissions": [
        "manage_roles",
        "manage_channels",
        "view_audit_log",
        "kick_members",
        "ban_members",
        "manage_messages",
        "move_members"
      ]
    },
    {
      "name": "Member",
      "color": "#27AE60",
      "hoist": false,
      "permissions": [
        "change_nickname",
        "send_messages",
        "embed_links",
        "attach_files",
        "read_message_history",
        "add_reactions",
        "connect",
        "speak",
        "use_voice_activation"
      ]
    }
  ],
  "categories": [
    {
      "name": "WAR COUNCIL",
      "channels": [
        {
          "name": "clan-command",
          "type": "text",
          "requires_staff": true,
          "slowmode": 0,
          "topic": "Private command center for {{community_name}} leadership.",
          "messages": [
            {
              "title": "Leadership Channel",
              "description": "Coordinate events, moderation, and roster planning in this restricted room.",
              "color": "#C0392B"
            }
          ]
        },
        {
          "name": "officer-briefing",
          "type": "voice",
          "requires_staff": true
        }
      ]
    },
    {
      "name": "CLAN HQ",
      "channels": [
        {
          "name": "announcements",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Clan updates, schedules, and important notices.",
          "messages": [
            {
              "title": "Welcome to {{community_name}}",
              "description": "Check in for raids, coordinate with the squad, and share your wins.",
              "color": "{{main_theme_color}}"
            }
          ]
        },
        {
          "name": "general-chat",
          "type": "text",
          "requires_staff": false,
          "slowmode": 3,
          "topic": "Daily banter, game talk, and member coordination."
        }
      ]
    },
    {
      "name": "SQUAD ZONE",
      "channels": [
        {
          "name": "looking-for-group",
          "type": "text",
          "requires_staff": false,
          "slowmode": 5,
          "topic": "Find teammates for sessions, events, or ranked queues."
        },
        {
          "name": "party-chat",
          "type": "voice",
          "requires_staff": false
        },
        {
          "name": "raid-room",
          "type": "voice",
          "requires_staff": false
        }
      ]
    }
  ]
}
